# .env — 配置文件（复制此文件为 .env 后填写，不要提交到 Git）

# ── Flask 运行参数 ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0          # 生产环境必须为 0

# ── 会话安全 ──────────────────────────────────────────────────────────
# 留空则每次启动自动随机生成（重启后所有用户需重新登录）
# 局域网部署建议填写固定值，如：openssl rand -hex 32
SECRET_KEY=""

# ── 访问码控制 ────────────────────────────────────────────────────────
# 设为 true 时，局域网用户需输入访问码才能使用
ENABLE_ACCESS_CODE=false
# 访问码内容（留空则每次启动随机生成）
ACCESS_CODE=""
# 登录会话有效期（秒），默认 8 小时
SESSION_LIFETIME=28800

# ── 并发限制 ──────────────────────────────────────────────────────────
# 同时处理的最大 LLM 任务数（防止多用户同时请求爆显存）
MAX_CONCURRENT_JOBS=3

# ── Gunicorn 参数 ─────────────────────────────────────────────────────
WORKERS=2              # Worker 进程数（LLM 模式建议 1~2）
THREADS=4              # 每 Worker 线程数
TIMEOUT=300            # 请求超时（秒），LLM 推理需要长一些
LOG_LEVEL=info

# ── LLM API Keys ──────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2048

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
QWEN_API_KEY=""
DEEPSEEK_API_KEY=""

# ── HuggingFace 本地推理 ──────────────────────────────────────────────
HF_TOKEN=""
HF_CACHE_DIR=""        # 留空使用默认 ~/.cache/huggingface
HF_DEVICE=auto         # auto | cpu | cuda | cuda:0 | mps
HF_TORCH_DTYPE=auto    # auto | float16 | bfloat16 | float32
