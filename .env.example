# .env — 配置文件（复制此文件为 .env 后填写）
# 此文件不要提交到 Git

# ── 默认 LLM ────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2048

# ── API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
QWEN_API_KEY=""
DEEPSEEK_API_KEY=""

# ── HuggingFace 本地推理 ─────────────────────────────────────────────
HF_TOKEN=""                         # 私有/门控模型需要
HF_CACHE_DIR="/data/hf_models"      # 权重缓存目录（留空使用默认 ~/.cache/huggingface）
HF_DEVICE="auto"                    # auto | cpu | cuda | cuda:0 | mps
HF_TORCH_DTYPE="auto"               # auto | float16 | bfloat16 | float32
